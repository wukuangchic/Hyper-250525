SIMPLE_HYPER_HOST=0.0.0.0
SIMPLE_HYPER_PORT=8787
SIMPLE_HYPER_COMMAND_TIMEOUT=300
SIMPLE_HYPER_CONNECTION_READ_TIMEOUT=15
SIMPLE_HYPER_MAX_CONCURRENT_COMMANDS=2
SIMPLE_HYPER_MAX_CONNECTIONS=32
SIMPLE_HYPER_MAX_COMMAND_LENGTH=240
# Production state should be outside the root-owned code tree.
# SIMPLE_HYPER_STATE_DIR=/var/lib/simple-hyper
# Optional HTTPS.
# SIMPLE_HYPER_TLS_CERT=/etc/simple-hyper/cert.pem
# SIMPLE_HYPER_TLS_KEY=/etc/simple-hyper/key.pem
