[Unit]
Description=Simple-Hyper trail/grid order worker
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=simplehyper
Group=simplehyper
WorkingDirectory=/opt/simple-hyper
Environment=SIMPLE_HYPER_STATE_DIR=/var/lib/simple-hyper
EnvironmentFile=-/opt/simple-hyper/simple-hyper.env
ExecStart=/opt/simple-hyper/.venv/bin/python /opt/simple-hyper/trail_worker.py
TimeoutStartSec=10min
UMask=0027
StateDirectory=simple-hyper
StateDirectoryMode=0750
